            memory: 512Mi
        volumeMounts:
        - mountPath: /stackable/log
          name: log
        - mountPath: /stackable/mount/config/datanode
          name: hdfs-config
        - mountPath: /stackable/mount/log/datanode
          name: hdfs-log-config
        - mountPath: /stackable/listener
          name: listener
{% if test_scenario['values']['datanode-pvcs'] == '2hdd-1ssd' %}
        - mountPath: /stackable/data/hdd
          name: hdd
        - mountPath: /stackable/data/hdd-1
          name: hdd-1
        - mountPath: /stackable/data/ssd
          name: ssd
{% else %}
