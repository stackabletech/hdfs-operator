apiVersion: apps/v1
kind: StatefulSet
metadata:
  labels:
    app.kubernetes.io/component: namenode
    app.kubernetes.io/instance: hdfs
    app.kubernetes.io/managed-by: hdfs.stackable.tech_hdfs-operator-hdfs-controller
    app.kubernetes.io/name: hdfs
    app.kubernetes.io/role-group: default
    stackable.tech/vendor: Stackable
  name: hdfs-namenode-default
  ownerReferences:
  - apiVersion: hdfs.stackable.tech/v1alpha1
    controller: true
    kind: HdfsCluster
    name: hdfs
spec:
  podManagementPolicy: OrderedReady
  replicas: 2
  selector:
    matchLabels:
      app.kubernetes.io/component: namenode
      app.kubernetes.io/instance: hdfs
      app.kubernetes.io/name: hdfs
      app.kubernetes.io/role-group: default
      group: default
      role: namenode
  serviceName: hdfs-namenode-default
  template:
    metadata:
      labels:
        app.kubernetes.io/component: namenode
        app.kubernetes.io/instance: hdfs
        app.kubernetes.io/name: hdfs
        app.kubernetes.io/role-group: default
        group: default
        role: namenode
    spec:
      affinity:
        podAffinity:
          preferredDuringSchedulingIgnoredDuringExecution:
          - podAffinityTerm:
              labelSelector:
                matchLabels:
                  app.kubernetes.io/instance: hdfs
                  app.kubernetes.io/name: hdfs
              topologyKey: kubernetes.io/hostname
            weight: 20
        podAntiAffinity:
          preferredDuringSchedulingIgnoredDuringExecution:
          - podAffinityTerm:
              labelSelector:
                matchLabels:
                  app.kubernetes.io/component: namenode
                  app.kubernetes.io/instance: hdfs
                  app.kubernetes.io/name: hdfs
              topologyKey: kubernetes.io/hostname
            weight: 70
      containers:
      - command:
        - /bin/bash
        - -x
        - -euo
        - pipefail
        - -c
        env:
        - name: COMMON_VAR
          value: group-value
        - name: CONTAINERDEBUG_LOG_DIRECTORY
          value: /stackable/log/containerdebug
        - name: GROUP_VAR
          value: group-value
        - name: HADOOP_CONF_DIR
          value: /stackable/config/namenode
        - name: HADOOP_HOME
          value: /stackable/hadoop
        - name: HADOOP_OPTS
        - name: HDFS_NAMENODE_OPTS
          value: -Xms819m -Xmx819m -Djava.security.properties=/stackable/config/namenode/security.properties
            -javaagent:/stackable/jmx/jmx_prometheus_javaagent.jar=8183:/stackable/jmx/namenode.yaml
        - name: POD_NAME
          valueFrom:
            fieldRef:
              apiVersion: v1
              fieldPath: metadata.name
        - name: ROLE_VAR
          value: role-value
        - name: ZOOKEEPER
          valueFrom:
            configMapKeyRef:
              key: ZOOKEEPER
              name: hdfs-znode
        livenessProbe:
          failureThreshold: 5
          initialDelaySeconds: 10
          periodSeconds: 10
          successThreshold: 1
          tcpSocket:
            port: http
          timeoutSeconds: 1
        name: namenode
        ports:
        - containerPort: 8020
          name: rpc
          protocol: TCP
        - containerPort: 9870
          name: http
          protocol: TCP
        readinessProbe:
          failureThreshold: 3
          initialDelaySeconds: 10
          periodSeconds: 10
          successThreshold: 1
          tcpSocket:
            port: rpc
          timeoutSeconds: 1
        resources:
          limits:
            cpu: "1"
            memory: 1Gi
          requests:
            cpu: 250m
            memory: 1Gi
        volumeMounts:
        - mountPath: /stackable/log
          name: log
        - mountPath: /stackable/mount/config/namenode
          name: hdfs-config
        - mountPath: /stackable/mount/log/namenode
          name: hdfs-log-config
        - mountPath: /stackable/listener
          name: listener
        - mountPath: /stackable/data
          name: data
      - command:
        - /bin/bash
        - -x
        - -euo
        - pipefail
        - -c
        env:
        - name: COMMON_VAR
          value: group-value
        - name: CONTAINERDEBUG_LOG_DIRECTORY
          value: /stackable/log/containerdebug
        - name: GROUP_VAR
          value: group-value
        - name: HADOOP_CONF_DIR
          value: /stackable/config/zkfc
        - name: HADOOP_HOME
          value: /stackable/hadoop
        - name: HADOOP_OPTS
        - name: POD_NAME
          valueFrom:
            fieldRef:
              apiVersion: v1
              fieldPath: metadata.name
        - name: ROLE_VAR
          value: role-value
        - name: ZOOKEEPER
          valueFrom:
            configMapKeyRef:
              key: ZOOKEEPER
              name: hdfs-znode
        name: zkfc
        resources:
          limits:
            cpu: 400m
            memory: 512Mi
          requests:
            cpu: 100m
            memory: 512Mi
        volumeMounts:
        - mountPath: /stackable/log
          name: log
        - mountPath: /stackable/mount/config/zkfc
          name: zkfc-config
        - mountPath: /stackable/mount/log/zkfc
          name: zkfc-log-config
{% if lookup('env', 'VECTOR_AGGREGATOR') %}
      - name: vector
{% endif %}
      enableServiceLinks: false
      initContainers:
      - command:
        - /bin/bash
        - -x
        - -euo
        - pipefail
        - -c
        env:
        - name: COMMON_VAR
          value: group-value
        - name: CONTAINERDEBUG_LOG_DIRECTORY
          value: /stackable/log/containerdebug
        - name: GROUP_VAR
          value: group-value
        - name: HADOOP_CONF_DIR
          value: /stackable/config/format-namenodes
        - name: HADOOP_HOME
          value: /stackable/hadoop
        - name: HADOOP_OPTS
        - name: POD_NAME
          valueFrom:
            fieldRef:
              apiVersion: v1
              fieldPath: metadata.name
        - name: ROLE_VAR
          value: role-value
        - name: ZOOKEEPER
          valueFrom:
            configMapKeyRef:
              key: ZOOKEEPER
              name: hdfs-znode
        name: format-namenodes
        resources:
          limits:
            cpu: "1"
            memory: 1Gi
          requests:
            cpu: 250m
            memory: 1Gi
        volumeMounts:
        - mountPath: /stackable/log
          name: log
        - mountPath: /stackable/mount/config/format-namenodes
          name: format-namenodes-config
        - mountPath: /stackable/mount/log/format-namenodes
          name: format-namenodes-log-config
        - mountPath: /stackable/data
          name: data
      - command:
        - /bin/bash
        - -x
        - -euo
        - pipefail
        - -c
        env:
        - name: COMMON_VAR
          value: group-value
        - name: CONTAINERDEBUG_LOG_DIRECTORY
          value: /stackable/log/containerdebug
        - name: GROUP_VAR
          value: group-value
        - name: HADOOP_CONF_DIR
          value: /stackable/config/format-zookeeper
        - name: HADOOP_HOME
          value: /stackable/hadoop
        - name: HADOOP_OPTS
        - name: POD_NAME
          valueFrom:
            fieldRef:
              apiVersion: v1
              fieldPath: metadata.name
        - name: ROLE_VAR
          value: role-value
        - name: ZOOKEEPER
          valueFrom:
            configMapKeyRef:
              key: ZOOKEEPER
              name: hdfs-znode
        name: format-zookeeper
        resources:
          limits:
            cpu: "1"
            memory: 1Gi
          requests:
            cpu: 250m
            memory: 1Gi
        volumeMounts:
        - mountPath: /stackable/log
          name: log
        - mountPath: /stackable/mount/config/format-zookeeper
          name: format-zookeeper-config
        - mountPath: /stackable/mount/log/format-zookeeper
          name: format-zookeeper-log-config
      securityContext:
        fsGroup: 1000
      serviceAccountName: hdfs-serviceaccount
      terminationGracePeriodSeconds: 900
      volumes:
      - emptyDir:
          sizeLimit: 150Mi
        name: log
      - configMap:
          name: hdfs-namenode-default
        name: hdfs-config
      - configMap:
          name: hdfs-namenode-default
        name: hdfs-log-config
      - configMap:
          name: hdfs-namenode-default
        name: zkfc-config
      - configMap:
          name: hdfs-namenode-default
        name: zkfc-log-config
      - configMap:
          name: hdfs-namenode-default
        name: format-namenodes-config
      - configMap:
          name: hdfs-namenode-default
        name: format-namenodes-log-config
      - configMap:
          name: hdfs-namenode-default
        name: format-zookeeper-config
      - configMap:
          name: hdfs-namenode-default
        name: format-zookeeper-log-config
  volumeClaimTemplates:
  - metadata:
      name: data
    spec:
      accessModes:
      - ReadWriteOnce
      resources:
        requests:
          storage: 2Gi
      volumeMode: Filesystem
  - metadata:
      annotations:
        listeners.stackable.tech/listener-class: {{ test_scenario['values']['listener-class'] }}
      labels:
        app.kubernetes.io/component: namenode
        app.kubernetes.io/instance: hdfs
        app.kubernetes.io/name: hdfs
        app.kubernetes.io/role-group: default
        group: default
        role: namenode
      name: listener
    spec:
      accessModes:
      - ReadWriteMany
      resources:
        requests:
          storage: "1"
      storageClassName: listeners.stackable.tech
      volumeMode: Filesystem
status:
  readyReplicas: 2
  replicas: 2
