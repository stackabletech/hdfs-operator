          value: -Xms409m -Xmx409m -Djava.security.properties=/stackable/config/datanode/security.properties
            -javaagent:/stackable/jmx/jmx_prometheus_javaagent.jar=8082:/stackable/jmx/datanode.yaml
        - name: POD_NAME
          valueFrom:
            fieldRef:
              apiVersion: v1
